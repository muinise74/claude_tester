{
  "name": "puppeteer-test-runner",
  "version": "1.0.0",
  "description": "Claude CLI + Puppeteer 기반 로컬 테스트 자동화 앱",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "marked": "^18.0.5",
    "puppeteer": "^21.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.puppeteer.testrunner",
    "productName": "Puppeteer Test Runner",
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "routines/**/*"
    ],
    "extraFiles": [
      {
        "from": "skills",
        "to": "skills"
      }
    ]
  }
}
